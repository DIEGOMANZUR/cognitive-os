# Copia este archivo a `.env.local` (ignorado por git) y rellena solo lo que vayas
# a usar. NO subas `.env.local`. OpenCode lee variables del entorno; expórtalas
# en tu shell o usa una herramienta como `direnv` / `dotenvx`.

# --- Context7 ---
# CONTEXT7_API_KEY=

# --- Neo4j (read-only por defecto en opencode.json) ---
# NEO4J_URI=bolt://localhost:7688
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j

# --- Weaviate (writes off por defecto en opencode.json) ---
# WEAVIATE_URL=http://localhost:8081
# WEAVIATE_API_KEY=

# --- LangSmith ---
# LANGSMITH_API_KEY=
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_WORKSPACE_ID=

# --- Perplexity Search / Grounding ---
# WEB_SEARCH_ENABLED=true
# PERPLEXITY_API_KEY=
# PERPLEXITY_BASE_URL=https://api.perplexity.ai

# --- Web search MCPs / runtime providers ---
# TAVILY_API_KEY=
# BRAVE_API_KEY=
# BRAVE_SEARCH_API_KEY=
# BRAVE_ANSWER_API_KEY=
# BRAVE_FREE_API_KEY=
# EXA_API_KEY=

# --- Hugging Face MCP ---
# HF_TOKEN=
# HUGGING_FACE_HUB_TOKEN=

# --- GitHub MCP (read-only) ---
# GITHUB_PERSONAL_ACCESS_TOKEN=
# GITHUB_READ_ONLY=true
# GITHUB_TOOLSETS=repos,issues,pull_requests,actions,code_security,users

# --- Memory Bank MCP ---
# MEMORY_BANK_ROOT=/absolute/path/to/memory-bank
