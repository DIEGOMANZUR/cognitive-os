NEO4J_PASSWORD=CHANGEME

# === Storage ===
STORAGE_BACKEND=filesystem
LOCAL_STORAGE_DIR=./storage
# Extra roots (comma paths) for POST /documents/ingest beyond LOCAL_STORAGE_DIR
DOCUMENT_INGEST_ALLOWED_PREFIXES=
