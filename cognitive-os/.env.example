# === Runtime ===
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_HOST=127.0.0.1
APP_PORT=8000

# === Security ===
JWT_SECRET=CHANGEME
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ADMIN_USER_IDS=
AUTH_DEFAULT_ROLES=operator
AUTH_ADMIN_ROLES=admin
# Comma-separated origins for browser CORS (empty = localhost:3000 defaults)
CORS_ALLOW_ORIGINS=

# === Primary LLM (strong model for chat / reasoning) ===
PRIMARY_LLM_PROVIDER=openai_compatible
PRIMARY_LLM_BASE_URL=https://your-openai-compatible-gateway/v1
PRIMARY_LLM_API_KEY=CHANGEME
PRIMARY_LLM_MODEL=gpt-5.5
# Leave empty unless your model supports OpenAI reasoning effort parameter
PRIMARY_LLM_REASONING_EFFORT=
# Set true only for models that accept the {"thinking":{"type":"enabled"}} body param
PRIMARY_LLM_THINKING_ENABLED=false

# === Agent LLM (DeepAgents + router / structured output) ===
# CRITICAL: this lane uses a FORCED tool_choice (structured output). The model
# MUST support forced tool_choice or every DeepAgent/router call fails HTTP 400
# and silently degrades to the deterministic/RAG fallback. DeepSeek's reasoner
# (deepseek-v4-pro) does NOT support it; deepseek-chat and gpt-5.5 do. Leave
# BASE_URL/API_KEY empty to reuse PRIMARY_*; set them only to point the agent
# lane at a different (tool-capable) endpoint.
AGENT_LLM_MODEL=gpt-5.5
AGENT_LLM_BASE_URL=
AGENT_LLM_API_KEY=

# === Secondary LLM (cheap model for summarization, classification, etc.) ===
SECONDARY_LLM_PROVIDER=openai_compatible
SECONDARY_LLM_BASE_URL=https://your-openai-compatible-gateway/v1
SECONDARY_LLM_API_KEY=CHANGEME
SECONDARY_LLM_MODEL=gemini-3.1-pro-low

# === FALLBACK LLM general (used when the primary circuit breaker is open) ===
# NO usar api.kimi.com/coding/v1: da HTTP 403 a clientes HTTP (Kimi-for-Coding
# solo coding agents). Cadena verificada: gateway openai-compatible.
FALLBACK_LLM_PROVIDER=openai_compatible
FALLBACK_LLM_BASE_URL=https://your-openai-compatible-gateway/v1
FALLBACK_LLM_API_KEY=CHANGEME
FALLBACK_LLM_MODEL=gemini-3.1-pro-low

# === Vision LLM (multimodal model for image/screenshot analysis) ===
VISION_LLM_PROVIDER=openai_compatible
VISION_LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
VISION_LLM_API_KEY=CHANGEME
VISION_LLM_MODEL=glm-4.6v
# Secondary vision model: GLM-4.6v de nuevo (verificado HTTP 200). NO Kimi
# HTTP (403). Kimi-2.6 visión solo serviría vía el adapter CLI del Code
# Director, nunca como endpoint ChatOpenAI.
VISION_FALLBACK_LLM_PROVIDER=openai_compatible
VISION_FALLBACK_LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
VISION_FALLBACK_LLM_API_KEY=CHANGEME
VISION_FALLBACK_LLM_MODEL=glm-4.6v

# === Embeddings ===
# provider ∈ {gemini, openai_compatible}
EMBEDDINGS_PROVIDER=gemini
EMBEDDINGS_BASE_URL=https://generativelanguage.googleapis.com/v1beta
EMBEDDINGS_API_KEY=CHANGEME
EMBEDDINGS_MODEL=gemini-embedding-001
EMBEDDINGS_DIMENSION=1536
# Gemini-only: task type hint per request (Matryoshka uses output_dimensionality).
EMBEDDINGS_TASK_TYPE_DOCUMENT=RETRIEVAL_DOCUMENT
EMBEDDINGS_TASK_TYPE_QUERY=RETRIEVAL_QUERY
# Optional comma-separated extra API keys; rotated automatically on 429/quota.
EMBEDDINGS_FALLBACK_API_KEYS=
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-base

# === Observability ===
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=CHANGEME
LANGSMITH_PERSONAL_ACCESS_TOKEN=CHANGEME
LANGSMITH_PROJECT=cognitive_os
# When true, /langsmith/* requires ADMIN_USER_IDS match or an admin JWT role
LANGSMITH_ENDPOINTS_REQUIRE_ADMIN=true
TRACE_REDACT_PII=true
TRACE_FULL_PAYLOADS=false
# Generate a high-entropy value for production. Fernet keys may be prefixed with fernet:.
ACTION_PAYLOAD_ENCRYPTION_KEY=CHANGEME
ACTION_PAYLOAD_ENCRYPTION_REQUIRED=false
HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RETRIES=2
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RESET_SECONDS=60

# === Databases ===
POSTGRES_USER=cogos
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=cognitive_os
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# pragma: allowlist nextline secret
DATABASE_URL=postgresql+asyncpg://cogos:CHANGEME@localhost:5432/cognitive_os
REDIS_URL=redis://localhost:6379/0
# Host port published by infra/docker-compose.yml (Redis bound to 127.0.0.1 only)
REDIS_PORT=6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=300
CELERY_TASK_TIME_LIMIT_SECONDS=360
CELERY_RESULT_EXPIRES_SECONDS=3600
WEAVIATE_URL=http://localhost:8081
WEAVIATE_HTTP_PORT=8081
WEAVIATE_GRPC_PORT=50052
WEAVIATE_API_KEY=CHANGEME
NEO4J_URI=bolt://localhost:7688
NEO4J_HTTP_PORT=7475
NEO4J_BOLT_PORT=7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGEME

# === Storage ===
STORAGE_BACKEND=filesystem
LOCAL_STORAGE_DIR=./storage
# Extra roots (comma paths) for POST /documents/ingest beyond LOCAL_STORAGE_DIR
DOCUMENT_INGEST_ALLOWED_PREFIXES=
BACKUP_DIR=./backups

# === Search ===
TAVILY_API_KEY=CHANGEME
WEB_SEARCH_ENABLED=false
PERPLEXITY_API_KEY=CHANGEME
PERPLEXITY_BASE_URL=https://api.perplexity.ai
EXA_API_KEY=CHANGEME
SERPER_API_KEY=CHANGEME
BRAVE_API_KEY=CHANGEME
BRAVE_ANSWER_API_KEY=CHANGEME
BRAVE_SEARCH_API_KEY=CHANGEME
BRAVE_FREE_API_KEY=CHANGEME

# === OpenHarness fusion (optional, research route) ===
# Bridge to upstream HKUDS/OpenHarness QueryEngine. Requires `uv sync --extra openharness`.
# See docs/OPENHARNESS_FUSION.md for the full contract; defaults below match Settings.
ENABLE_OPENHARNESS_RESEARCH=false
# `prelude_merge` (default): siempre llama DeepAgent y le inyecta el preludio OH.
# `short_circuit`: si OpenHarness responde, no se llama DeepAgent.
OPENHARNESS_RESEARCH_PIPELINE=prelude_merge
# `minimal` | `research` (default) | `full`. Detalle de tools en docs/OPENHARNESS_FUSION.md.
OPENHARNESS_TOOLKIT_PRESET=research
# `deepagent_mirror` (default) | `sandbox`. En `sandbox` usa OPENHARNESS_WORKSPACE.
OPENHARNESS_WORKSPACE_MODE=deepagent_mirror
OPENHARNESS_WORKSPACE=./storage/openharness_workspace
# Solo aplica al preset `minimal` (los presets research/full ya incluyen file tools).
OPENHARNESS_INCLUDE_FILE_TOOLS=false
# Web dentro del harness exige WEB_SEARCH_ENABLED=true Y este flag.
OPENHARNESS_WEB_TOOLS=true
OPENHARNESS_QUERY_TIMEOUT_SECONDS=180
OPENHARNESS_MAX_TURNS=16

# === Telegram ===
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=CHANGEME
TELEGRAM_AUTHORIZED_USER_IDS=
# Personal assistant (Tasks/Notes) + Telegram → API user binding (comma-separated chat_id:user_id pairs)
ENABLE_PERSONAL_ASSISTANT_API=true
ENABLE_PERSONAL_REMINDER_DELIVERY=false
TELEGRAM_ASSIST_USER_MAP=
TELEGRAM_REMINDER_CHAT_MAP=
TELEGRAM_GMAIL_DIGEST_ENABLED=false
TELEGRAM_GMAIL_DIGEST_CHAT_IDS=
TELEGRAM_GMAIL_DIGEST_HOUR_UTC=8
TELEGRAM_GMAIL_DIGEST_LOOKBACK_HOURS=24

# === Operator profile ===
# Selects friction/safety defaults.
#   strict           = multi-tenant / production. Approval gates ON,
#                      four-eyes required, conservative budgets.
#   dedicated_local  = single-operator PC. Approval relaxed for reversible
#                      actions (drive_ensure_folder, drive_upload propio),
#                      four-eyes off, approval-pending TTL 168h.
# Mail send, browser, openshell, code_build, drive_organize_files SIEMPRE
# requieren approval — incluso bajo dedicated_local (irreversibles).
OPERATOR_PROFILE=strict
# Auto-approve whitelist for reversible actions when running as dedicated_local.
# `apply_operator_profile_defaults` flips this to true when profile is
# dedicated_local AND the operator did not set it. Leave commented to honour
# the profile-derived default; set explicit only to override.
# AUTO_APPROVE_REVERSIBLE_ACTIONS=false

# === Tools policy ===
TOOLS_READONLY_MODE=true
REQUIRE_HUMAN_APPROVAL_FOR_EXTERNAL_ACTIONS=true
ENABLE_BROWSER_AUTOMATION=false
ENABLE_COMPUTER_ACTIONS=false
ENABLE_EMAIL_SEND=false
ENABLE_SOCIAL_POSTING=false
ALLOW_DANGEROUS_TOOLS=false

# === Code Director ===
# Budget enforcement mode.
#   soft = guideline; the build ends `partial` between subtasks but a subtask
#          is never killed mid-call.
#   hard = budget gated BEFORE every adapter call; subprocess timeout is
#          clamped to the remaining runtime budget so a single subtask cannot
#          run past the cap. Default under dedicated_local is `soft`.
CODE_DIRECTOR_BUDGET_MODE=soft

# === Computer / Local Filesystem Actions ===
# Empty = no real filesystem roots are action-enabled. Preview tools still work on safe inputs.
COMPUTER_ALLOWED_ROOTS=
COMPUTER_ORGANIZE_DRY_RUN_ONLY=true
COMPUTER_MAX_FILES_PER_PLAN=500

# === Document Generation ===
ENABLE_DOCUMENT_GENERATION=true
DOCUMENT_OUTPUT_ROOT=./storage/documents
# Comma-separated image roots for DOCX/PPTX assets. Empty = image embedding disabled.
DOCUMENT_ASSET_ROOTS=./storage/documents/assets
DOCUMENT_MAX_SIZE_BYTES=10485760

# === Browser / Computer Automation ===
# provider ∈ {playwright, camoufox}; Camoufox keeps Playwright-style APIs.
BROWSER_AUTOMATION_PROVIDER=playwright
BROWSER_HEADLESS_DEFAULT=true
BROWSER_ALLOW_HEADED=false
BROWSER_ALLOW_VISION=false
# Empty = no allow-list yet. Prefer explicit domains before enabling real actions.
BROWSER_ALLOWED_DOMAINS=
BROWSER_PROFILE_DIR=./storage/browser/profiles
BROWSER_DOWNLOAD_DIR=./storage/browser/downloads
BROWSER_SESSION_TTL_SECONDS=900
BROWSER_MAX_PAGES_PER_TASK=5
BROWSER_SCREENSHOT_DIR=./storage/browser/screenshots
BROWSER_NAVIGATION_TIMEOUT_MS=20000
BROWSER_SCREENSHOT_MAX_BYTES=5242880
ENABLE_BROWSER_SSRF_CHECK=true
ACTION_REQUEST_RUNNING_MAX_MINUTES=60

# === Research Orchestrator ===
ENABLE_RESEARCH_ORCHESTRATOR=true
RESEARCH_MAX_PARALLEL_WORKERS=4
RESEARCH_MAX_TIME_BUDGET_SECONDS=300
RESEARCH_MAX_SUBTASKS=8
RESEARCH_PERSISTENCE_BACKEND=memory

# === Mail & Registrar Integrations ===
GMAIL_READ_ENABLED=false
GMAIL_SEND_ENABLED=false
GMAIL_CLIENT_ID=CHANGEME
GMAIL_CLIENT_SECRET=CHANGEME
GMAIL_TOKEN_DIR=./storage/oauth/gmail
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# === Google APIs: Calendar + Drive (shared OAuth client) + Maps (API key) ===
# GOOGLE_CLIENT_ID/SECRET come from a Google Cloud "Desktop app" OAuth client.
# Run `python scripts/auth_google.py` once to generate the local token.json.
GOOGLE_CLIENT_ID=CHANGEME
GOOGLE_CLIENT_SECRET=CHANGEME
GOOGLE_TOKEN_DIR=./storage/oauth/google
ENABLE_GOOGLE_CALENDAR=false
ENABLE_GOOGLE_CALENDAR_WRITE=false
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.events,https://www.googleapis.com/auth/calendar.freebusy
ENABLE_GOOGLE_DRIVE=false
ENABLE_GOOGLE_DRIVE_WRITE=false
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive
GOOGLE_DRIVE_UPLOAD_MAX_BYTES=52428800
GOOGLE_DRIVE_DELIVERABLES_FOLDER_NAME=Cognitive OS Deliverables
# Maps uses a plain API key (restrict it to Routes API + Geocoding API).
GOOGLE_MAPS_API_KEY=CHANGEME
GOOGLE_MAPS_BASE_URL=https://maps.googleapis.com
ENABLE_MAPS_ROUTING=false
MAPS_DEFAULT_TRAVEL_MODE=driving

# Personal multi-account mail assistant. GoDaddy IMAP/SMTP is the only sender;
