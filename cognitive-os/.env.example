GODADDY_ENABLED=false
GODADDY_BASE_URL=https://api.godaddy.com
GODADDY_API_KEY=CHANGEME
GODADDY_API_SECRET=CHANGEME
# Empty = no DNS write target is executable. Use OTE first.
GODADDY_ALLOWED_DOMAINS=
GODADDY_DNS_DRY_RUN_ONLY=true
GODADDY_ALLOW_PRODUCTION_WRITES=false
GODADDY_MAX_REQUESTS_PER_MINUTE=60

# === OpenShell Sandbox ===
ENABLE_OPENSHELL_SANDBOX=false
OPENSHELL_PROJECT_DIR=./experiments/openshell-deepagent
OPENSHELL_SANDBOX_NAME=cognitive-os-sandbox
