# --- Secrets & environment ---
.env
.env.*
!.env.example
!.env.local.example
*.pem
*.key

# --- Python / Node build & cache artifacts ---
.venv/
node_modules/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# --- Runtime data (never source) ---
data/
models/
storage/
*.sqlite
*.db
*.bak-*

# --- Session work logs (bitácora). Local working files, not product
#     documentation — kept out of version control per AUDIT-2026-I. ---
task_plan.local.md
findings.local.md
progress.local.md
cognitive-os/task_plan.md
cognitive-os/findings.md
cognitive-os/progress.md

# --- TestSprite generated suites (regenerated on demand) ---
testsprite_tests/
cognitive-os/frontend/testsprite_tests/

# --- Project snapshots/backups are read-only recovery material, never source. ---
cognitive-os-backup-*/
cognitive-os-snapshot-*/

# --- Audit/QA evidence is a local artifact tree: full-qa logs, Playwright
#     traces/screenshots/videos, TestSprite raw reports, stress-qa runs.
#     The audit docs reference these paths as evidence-at-commit-time; the
#     artifacts themselves are reproduced by re-running the gates. ---
cognitive-os/test-results/

# --- Read-only audit sandboxes (e.g. `tmp/commercial_audit_<timestamp>/`).
#     Local entregables of audit passes; canonical conclusions live in docs/. ---
tmp/

# --- Local tool settings (machine-specific permissions or paths) ---
**/.claude/settings.local.json
**/.claude/scheduled_tasks.lock

# --- Recovered transcripts may contain pasted credentials or private context. ---
conversacion_recuperada_codex_claude.md
sesion_14_15_mayo_completa.md
