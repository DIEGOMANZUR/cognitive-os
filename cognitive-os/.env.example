# === Runtime ===
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_HOST=127.0.0.1
APP_PORT=8000

# === Security ===
JWT_SECRET=CHANGEME
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ADMIN_USER_IDS=
AUTH_DEFAULT_ROLES=operator
AUTH_ADMIN_ROLES=admin
# Comma-separated origins for browser CORS (empty = localhost:3000 defaults)
CORS_ALLOW_ORIGINS=

# === Primary LLM (strong model for chat / reasoning) ===
PRIMARY_LLM_PROVIDER=openai_compatible
PRIMARY_LLM_BASE_URL=https://your-openai-compatible-gateway/v1
PRIMARY_LLM_API_KEY=CHANGEME
PRIMARY_LLM_MODEL=gpt-5.5
# Leave empty unless your model supports OpenAI reasoning effort parameter
PRIMARY_LLM_REASONING_EFFORT=
# Set true only for models that accept the {"thinking":{"type":"enabled"}} body param
PRIMARY_LLM_THINKING_ENABLED=false

# === Responses API + prompt caching (Fase 79.1) ===
# Gateway-side OpenAI Responses API at `POST /v1/responses` with 24h
# prompt-cache retention. With this ON, ALL 6 LLM lanes (primary, agent,
# secondary, fallback, vision, vision_fb) call /v1/responses with a stable
# `prompt_cache_key` per role. Huge saving on the recipe extractor and
# router LLM since they reuse long system + few-shot prompts every call.
# Flip to false ONLY if you point a lane at a provider that does NOT
# implement Responses API (uncommon for openai-compatible gateways in 2026).
LLM_USE_RESPONSES_API=true
LLM_PROMPT_CACHE_ENABLED=true
# Namespace prepended to the per-role cache key. Bump after a non-trivial
# system-prompt edit to force a fresh cache cycle.
LLM_PROMPT_CACHE_NAMESPACE=cognitive-os-v1

# === Agent LLM (DeepAgents + router / structured output) ===
# CRITICAL: this lane uses a FORCED tool_choice (structured output). The model
# MUST support forced tool_choice or every DeepAgent/router call fails HTTP 400
# and silently degrades to the deterministic/RAG fallback. DeepSeek's reasoner
# (deepseek-v4-pro) does NOT support it; deepseek-chat and gpt-5.5 do. Leave
# BASE_URL/API_KEY empty to reuse PRIMARY_*; set them only to point the agent
# lane at a different (tool-capable) endpoint.
AGENT_LLM_MODEL=gpt-5.5
AGENT_LLM_BASE_URL=
AGENT_LLM_API_KEY=

# === Secondary LLM (cheap model for summarization, classification, etc.) ===
SECONDARY_LLM_PROVIDER=openai_compatible
SECONDARY_LLM_BASE_URL=https://your-openai-compatible-gateway/v1
SECONDARY_LLM_API_KEY=CHANGEME
SECONDARY_LLM_MODEL=gemini-3.1-pro-low

# === FALLBACK LLM general (used when the primary circuit breaker is open) ===
# NO usar api.kimi.com/coding/v1: da HTTP 403 a clientes HTTP (Kimi-for-Coding
# solo coding agents). Cadena verificada: gateway openai-compatible.
FALLBACK_LLM_PROVIDER=openai_compatible
FALLBACK_LLM_BASE_URL=https://your-openai-compatible-gateway/v1
FALLBACK_LLM_API_KEY=CHANGEME
FALLBACK_LLM_MODEL=gemini-3.1-pro-low

# === Vision LLM (multimodal model for image/screenshot analysis) ===
VISION_LLM_PROVIDER=openai_compatible
VISION_LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
VISION_LLM_API_KEY=CHANGEME
VISION_LLM_MODEL=glm-4.6v
# Secondary vision model: GLM-4.6v de nuevo (verificado HTTP 200). NO Kimi
# HTTP (403). Kimi-2.6 visión solo serviría vía el adapter CLI del Code
# Director, nunca como endpoint ChatOpenAI.
VISION_FALLBACK_LLM_PROVIDER=openai_compatible
VISION_FALLBACK_LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
VISION_FALLBACK_LLM_API_KEY=CHANGEME
VISION_FALLBACK_LLM_MODEL=glm-4.6v

# === Embeddings ===
# provider ∈ {gemini, openai_compatible}
EMBEDDINGS_PROVIDER=gemini
EMBEDDINGS_BASE_URL=https://generativelanguage.googleapis.com/v1beta
EMBEDDINGS_API_KEY=CHANGEME
EMBEDDINGS_MODEL=gemini-embedding-001
EMBEDDINGS_DIMENSION=1536
# Gemini-only: task type hint per request (Matryoshka uses output_dimensionality).
EMBEDDINGS_TASK_TYPE_DOCUMENT=RETRIEVAL_DOCUMENT
EMBEDDINGS_TASK_TYPE_QUERY=RETRIEVAL_QUERY
# Optional comma-separated extra API keys; rotated automatically on 429/quota.
EMBEDDINGS_FALLBACK_API_KEYS=
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-base

# === Observability ===
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=CHANGEME
LANGSMITH_PERSONAL_ACCESS_TOKEN=CHANGEME
LANGSMITH_PROJECT=cognitive_os
# When true, /langsmith/* requires ADMIN_USER_IDS match or an admin JWT role
LANGSMITH_ENDPOINTS_REQUIRE_ADMIN=true
TRACE_REDACT_PII=true
TRACE_FULL_PAYLOADS=false
# Generate a high-entropy value for production. Fernet keys may be prefixed with fernet:.
ACTION_PAYLOAD_ENCRYPTION_KEY=CHANGEME
ACTION_PAYLOAD_ENCRYPTION_REQUIRED=false
HTTP_TIMEOUT_SECONDS=15
# Hard cap per /health/dashboard component so one stuck dependency cannot hang the UI.
HEALTH_COMPONENT_TIMEOUT_SECONDS=3
HTTP_MAX_RETRIES=2
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RESET_SECONDS=60

# === Databases ===
POSTGRES_USER=cogos
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=cognitive_os
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# pragma: allowlist nextline secret
DATABASE_URL=postgresql+asyncpg://cogos:CHANGEME@localhost:5432/cognitive_os
# Test database (opcional). La suite pytest NUNCA toca la DB de producción:
# `tests/conftest.py` redirige DATABASE_URL a una DB `_test` dedicada que se
# recrea + migra a head en cada corrida. Por defecto se deriva del
# DATABASE_URL de arriba agregando `_test` al nombre (→ cognitive_os_test).
# Descomentá para apuntar a otra DB; su nombre DEBE contener 'test'.
# pragma: allowlist nextline secret
#TEST_DATABASE_URL=postgresql+asyncpg://cogos:CHANGEME@localhost:5432/cognitive_os_test
REDIS_URL=redis://localhost:6379/0
# Host port published by infra/docker-compose.yml (Redis bound to 127.0.0.1 only)
REDIS_PORT=6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=300
CELERY_TASK_TIME_LIMIT_SECONDS=360
CELERY_RESULT_EXPIRES_SECONDS=3600
WEAVIATE_URL=http://localhost:8081
WEAVIATE_HTTP_PORT=8081
WEAVIATE_GRPC_PORT=50052
WEAVIATE_API_KEY=CHANGEME
NEO4J_URI=bolt://localhost:7688
NEO4J_HTTP_PORT=7475
NEO4J_BOLT_PORT=7688
