# === Search ===
TAVILY_API_KEY=CHANGEME
WEB_SEARCH_ENABLED=false
PERPLEXITY_API_KEY=CHANGEME
PERPLEXITY_BASE_URL=https://api.perplexity.ai
EXA_API_KEY=CHANGEME
SERPER_API_KEY=CHANGEME
BRAVE_API_KEY=CHANGEME
BRAVE_ANSWER_API_KEY=CHANGEME
BRAVE_SEARCH_API_KEY=CHANGEME
BRAVE_FREE_API_KEY=CHANGEME

# === OpenHarness fusion (optional, research route) ===
# Bridge to upstream HKUDS/OpenHarness QueryEngine. Requires `uv sync --extra openharness`.
# See docs/OPENHARNESS_FUSION.md for the full contract; defaults below match Settings.
ENABLE_OPENHARNESS_RESEARCH=false
# `prelude_merge` (default): siempre llama DeepAgent y le inyecta el preludio OH.
# `short_circuit`: si OpenHarness responde, no se llama DeepAgent.
OPENHARNESS_RESEARCH_PIPELINE=prelude_merge
# `minimal` | `research` (default) | `full`. Detalle de tools en docs/OPENHARNESS_FUSION.md.
OPENHARNESS_TOOLKIT_PRESET=research
# `deepagent_mirror` (default) | `sandbox`. En `sandbox` usa OPENHARNESS_WORKSPACE.
OPENHARNESS_WORKSPACE_MODE=deepagent_mirror
OPENHARNESS_WORKSPACE=./storage/openharness_workspace
# Solo aplica al preset `minimal` (los presets research/full ya incluyen file tools).
OPENHARNESS_INCLUDE_FILE_TOOLS=false
# Web dentro del harness exige WEB_SEARCH_ENABLED=true Y este flag.
OPENHARNESS_WEB_TOOLS=true
OPENHARNESS_QUERY_TIMEOUT_SECONDS=180
OPENHARNESS_MAX_TURNS=16

# === Telegram ===
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=CHANGEME
TELEGRAM_AUTHORIZED_USER_IDS=
# Personal assistant (Tasks/Notes) + Telegram → API user binding (comma-separated chat_id:user_id pairs)
ENABLE_PERSONAL_ASSISTANT_API=true
ENABLE_PERSONAL_REMINDER_DELIVERY=false
TELEGRAM_ASSIST_USER_MAP=
TELEGRAM_REMINDER_CHAT_MAP=
TELEGRAM_GMAIL_DIGEST_ENABLED=false
TELEGRAM_GMAIL_DIGEST_CHAT_IDS=
TELEGRAM_GMAIL_DIGEST_HOUR_UTC=8
TELEGRAM_GMAIL_DIGEST_LOOKBACK_HOURS=24

# === Operator profile ===
# Selects friction/safety defaults.
#   strict           = multi-tenant / production. Approval gates ON,
#                      four-eyes required, conservative budgets.
#   dedicated_local  = single-operator PC. With LOCAL_AUTONOMY_MODE=full,
#                      approvals are removed for local/browser/Google
#                      workflows; audit/events/idempotency remain mandatory.
#                      Mail stays read-only by policy unless Diego asks for
#                      a specific explicit send.
OPERATOR_PROFILE=strict
# full    = zero-friction dedicated PC. Overrides legacy approval-heavy flags.
# guarded = old local mode; explicit approval flags in .env keep winning.
LOCAL_AUTONOMY_MODE=full
# Auto-approve whitelist for reversible actions when running as dedicated_local.
# `apply_operator_profile_defaults` flips this to true when profile is
# dedicated_local AND the operator did not set it. Leave commented to honour
# the profile-derived default; set explicit only to override.
# AUTO_APPROVE_REVERSIBLE_ACTIONS=false

# === Tools policy ===
TOOLS_READONLY_MODE=true
REQUIRE_HUMAN_APPROVAL_FOR_EXTERNAL_ACTIONS=true
ENABLE_BROWSER_AUTOMATION=false
ENABLE_COMPUTER_ACTIONS=false
ENABLE_EMAIL_SEND=false
ENABLE_SOCIAL_POSTING=false
ALLOW_DANGEROUS_TOOLS=false

# === Code Director ===
# Budget enforcement mode.
#   soft = guideline; the build ends `partial` between subtasks but a subtask
#          is never killed mid-call.
#   hard = budget gated BEFORE every adapter call; subprocess timeout is
#          clamped to the remaining runtime budget so a single subtask cannot
#          run past the cap. Default under dedicated_local is `soft`.
CODE_DIRECTOR_BUDGET_MODE=soft

# === Computer / Local Filesystem Actions ===
# Empty = no real filesystem roots are action-enabled. Preview tools still work on safe inputs.
COMPUTER_ALLOWED_ROOTS=
COMPUTER_ORGANIZE_DRY_RUN_ONLY=true
COMPUTER_MAX_FILES_PER_PLAN=500

# === Document Generation ===
ENABLE_DOCUMENT_GENERATION=true
DOCUMENT_OUTPUT_ROOT=./storage/documents
# Comma-separated image roots for DOCX/PPTX assets. Empty = image embedding disabled.
DOCUMENT_ASSET_ROOTS=./storage/documents/assets
DOCUMENT_MAX_SIZE_BYTES=10485760

# === Browser / Computer Automation ===
# provider ∈ {playwright, camoufox}; Camoufox keeps Playwright-style APIs.
BROWSER_AUTOMATION_PROVIDER=playwright
BROWSER_HEADLESS_DEFAULT=true
BROWSER_ALLOW_HEADED=false
BROWSER_ALLOW_VISION=false
# Empty = no allow-list yet. Prefer explicit domains before enabling real actions.
BROWSER_ALLOWED_DOMAINS=
BROWSER_PROFILE_DIR=./storage/browser/profiles
BROWSER_DOWNLOAD_DIR=./storage/browser/downloads
BROWSER_SESSION_TTL_SECONDS=900
BROWSER_MAX_PAGES_PER_TASK=5
BROWSER_SCREENSHOT_DIR=./storage/browser/screenshots
BROWSER_NAVIGATION_TIMEOUT_MS=20000
BROWSER_SCREENSHOT_MAX_BYTES=5242880
ENABLE_BROWSER_SSRF_CHECK=true
ACTION_REQUEST_RUNNING_MAX_MINUTES=60

# === Research Orchestrator ===
ENABLE_RESEARCH_ORCHESTRATOR=true
RESEARCH_MAX_PARALLEL_WORKERS=4
RESEARCH_MAX_TIME_BUDGET_SECONDS=300
RESEARCH_MAX_SUBTASKS=8
RESEARCH_PERSISTENCE_BACKEND=memory

