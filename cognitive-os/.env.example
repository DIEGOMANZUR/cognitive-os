DEEPAGENTS_MEMORY_REDACT_PII=true

# === Plan de aprendizaje autónomo (Fases 78-81) ===
# Todos los valores tienen default en config.py; descomentá sólo para
# ajustar cadencia o desactivar una fase. Todo el aprendizaje pasa por
# el approval gate del operador — cero auto-deploy de comportamiento.
#
# Fase A — Recipe extractor: distila jobs exitosos en recetas (procedure).
RECIPE_EXTRACTOR_ENABLED=true
RECIPE_EXTRACTOR_CRON=*/30 * * * *
RECIPE_EXTRACTOR_MIN_TOOL_CALLS=5
RECIPE_EXTRACTOR_MIN_DURATION_SECONDS=30
RECIPE_EXTRACTOR_MAX_PER_CYCLE=20
# Fase D — Failure post-mortem: detecta patrones fallo→recuperación.
FAILURE_POSTMORTEM_ENABLED=true
FAILURE_POSTMORTEM_CRON=35 3 * * *
FAILURE_POSTMORTEM_AUTOPROMOTE_THRESHOLD=3
FAILURE_POSTMORTEM_MAX_REJECTIONS=2
# Kill switch del único auto-deploy del plan de aprendizaje (AUDIT-2026-C).
# true (default, zero-friction): una warning recurrente se vuelve memoria
# activa sin aprobación. false: toda warning aprendida pasa por la puerta
# de aprobación del operador — literal "cero auto-deploy".
FAILURE_POSTMORTEM_AUTO_PROMOTE_ENABLED=true
# Fase C — Tool scorecard: rollup diario de confiabilidad por tool.
TOOL_SCORECARD_ENABLED=true
TOOL_SCORECARD_CRON=15 4 * * *
# Fase B — Skill promoter: promueve procedures usados a skills YAML.
SKILL_PROMOTER_ENABLED=true
SKILL_PROMOTER_CRON=45 4 * * *
SKILL_PROMOTER_MIN_SUCCESSES=3
SKILL_PROMOTER_MAX_FAILURE_RATE=0.3
SKILL_PROMOTER_ROLLBACK_WINDOW_DAYS=30
SKILL_PROMOTER_ROLLBACK_MAX_FAILURE_RATE=0.5
# Fase E — Nightly reflection: el LLM revisa los threads del día y
# propone preferences/lessons con evidencia literal obligatoria.
NIGHTLY_REFLECTION_ENABLED=true
NIGHTLY_REFLECTION_CRON=0 3 * * *
NIGHTLY_REFLECTION_LOOKBACK_HOURS=24
NIGHTLY_REFLECTION_MAX_THREADS_PER_CYCLE=30
NIGHTLY_REFLECTION_MIN_CONFIDENCE=0.7
NIGHTLY_REFLECTION_MAX_REJECTION_RATE=0.5

# === MCP client (Fase 73 + 77) ===
# Sintaxis CSV: name:transport:target[::k=v,k=v]
# Transports: sse | streamable_http | stdio
# Server set sugerido (dedicated_local):
#   - mem: Supermemory MCP (memoria compartida con Claude Code) — PROTEGIDO
#   - gh:  GitHub MCP remoto (issues/PRs/code search)
#   - fs:  filesystem local del operador (alcance configurable)
#   - cc:  Claude Code one-shot via @steipete/claude-code-mcp (CLI `claude` requerido)
#   - gem: Gemini CLI via gemini-mcp-tool (CLI `gemini` requerido + auth interactiva)
ENABLE_MCP_CLIENT=false
MCP_SERVERS=mem:streamable_http:https://api.supermemory.ai/mcp::header_Authorization=Bearer CHANGEME,gh:streamable_http:https://api.githubcopilot.com/mcp::header_Authorization=Bearer CHANGEME,fs:stdio:npx -y @modelcontextprotocol/server-filesystem /home/CHANGEME,cc:stdio:npx -y @steipete/claude-code-mcp,gem:stdio:npx -y gemini-mcp-tool
MCP_CALL_TIMEOUT_SECONDS=30
MCP_INVENTORY_TIMEOUT_SECONDS=5
MCP_ALLOWED_FOR_RESEARCH=
MCP_ALLOWED_FOR_DOCUMENT_ANALYSIS=
